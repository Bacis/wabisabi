      {
        "time_range": "00:14.000 - 00:24.000",
        "speaker": "German Fan",
        "text": "RIGHT UP",
        "classes": [
          "german-standard"
        ]
      },
      {
        "time_range": "00:14.000 - 00:24.000",
        "speaker": "German Fan",
        "text": "THEEEEEEERE.",
        "classes": [
          "emphasis-stretch"
        ]
      },
      {
        "time_range": "00:25.000 - 00:41.000",
        "speaker": "Trevor",
        "text": "What are you guys doing out here in Austin?",
