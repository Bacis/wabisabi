        "time_range": "00:25.000 - 00:41.000",
        "speaker": "German Fan",
        "text": "We're doing an EXCHANGE.",
        "classes": [
          "german-standard"
        ]
      },
      {
        "time_range": "00:25.000 - 00:41.000",
        "speaker": "Trevor",
        "text": "Nice. What's your favorite and least favorite thing about America so far?",
        "classes": [
          "trevor-standard"
        ]
      },
      {
        "time_range": "00:25.000 - 00:41.000",
        "speaker": "German Fan",
        "text": "The girls are STUPID.",
