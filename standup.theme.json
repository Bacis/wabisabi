        "time_range": "00:03.000 - 00:14.000",
        "speaker": "German Fan",
        "text": "It sounds fine.",
        "classes": [
          "german-standard"
        ]
      },
      {
        "time_range": "00:03.000 - 00:14.000",
        "speaker": "Trevor",
        "text": "Buddy... My ancestors are being like...",
