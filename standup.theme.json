          "german-standard"
        ]
      },
      {
        "time_range": "00:42.000 - 00:52.000",
        "speaker": "Trevor",
        "text": "That's America brother.",
        "classes": [
          "trevor-standard",
          "b-roll-trigger"
        ],
        "b_roll_details": "Bald eagles flying with screech SFX"
      },
      {
        "time_range": "00:53.000 - 01:14.000",
