          "emphasis-shout"
        ]
      },
      {
        "time_range": "00:03.000 - 00:14.000",
        "speaker": "Trevor",
        "text": "GET HIM OUT!!!",
        "classes": [
          "emphasis-shout"
        ]
      },
      {
        "time_range": "00:03.000 - 00:14.000",
        "speaker": "Trevor",
        "text": "What's your guys story?",
        "classes": [
          "trevor-standard"
        ]
