        "b_roll_details": "German flag PNG overlay"
      },
      {
        "time_range": "00:14.000 - 00:24.000",
        "speaker": "Trevor",
        "text": "Oh shit.",
        "classes": [
          "trevor-standard"
        ]
      },
      {
        "time_range": "00:14.000 - 00:24.000",
        "speaker": "Trevor",
        "text": "I'm JEWISH",
