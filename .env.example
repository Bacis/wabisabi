SQLITE_PATH=./storage/captions.db
STORAGE_DIR=./storage
REMOTION_PROJECT=./remotion
PYTHON_BIN=python3
TRANSCRIBE_SCRIPT=./transcribe-py/transcribe.py
PORT=3000

# Render mode: "local" (default — local Chromium via @remotion/renderer)
# or "lambda" (deploy/render on AWS Lambda via @remotion/lambda).
#
# On Railway / any 24-7 deployment, prefer RENDER_MODE=lambda — it keeps
# the container small (no Chromium CPU, no large output files on disk)
# and every finished mp4 lands in S3 under the `jobs/` or `productions/`
# prefix. The API serves them via presigned redirects from GET
# /jobs/:id/output. See src/lib/s3Outputs.ts for the managed prefixes +
# lifecycle rules (1d on jobs/ and staged inputs, 7d on productions/).
RENDER_MODE=local

# Required when RENDER_MODE=lambda. The first job in lambda mode deploys
# the Remotion function + site to your AWS account (~60-90s) and caches
# the resulting names in storage/lambda-state.json. Delete that file to
# force a fresh deploy after composition changes.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY belong in .env (gitignored).

# Optional Lambda tuning. Lower framesPerLambda = more parallel chunks =
# faster wall-clock but more cold starts. Default 50.
LAMBDA_FRAMES=50

# --- Storage / retention ---
# TTS cache size cap (MB). The ElevenLabs cache is content-addressable so
# cache hits are free, but unique narration text accumulates forever
# without a cap. Default 500 MB; lower on small Railway volumes.
# TTS_CACHE_MAX_MB=500

# --- Video producer feature (multi-file story + narration) ---

# Anthropic API key. Shared with the single-video caption pipeline. Required
# for: asset classification (Claude multimodal), style generation, and the
# producer orchestrator agent. Producer still runs without it — each LLM
# call falls back to deterministic logic and logs a warning.
# ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs TTS for narrated_story mode. If unset, narrated_story
# productions render silent (no voiceover). Find voice IDs in the
# ElevenLabs dashboard; the default multilingual model covers most voices.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# HuggingFace token for speaker diarization (pyannote). Only needed to
# classify individual speakers within a video in Speaker Montage mode.
# Without it, diarize.py soft-fails and we rely on word-count heuristics.
# Accept the model license at huggingface.co/pyannote/speaker-diarization-3.1
# HUGGINGFACE_TOKEN=

# --- Telegram bot (optional) ---
# When set, scripts/start.sh launches a 4th process that exposes the
# producer pipeline to Telegram group chats. Users @mention the bot in
# a group, attach 1+ photos/videos (Telegram albums work), and the bot
# replies with a rendered MP4 when the job finishes.
#
# Get a token from @BotFather. Configure /setprivacy → Disable so the
# bot can read group messages (required for @mention detection), and
# /setjoingroups → Enable.
# TELEGRAM_BOT_TOKEN=
#
# Where the bot posts submissions. Defaults to http://127.0.0.1:$PORT
# which matches the loopback API running in the same container.
# TELEGRAM_API_BASE=http://127.0.0.1:3000
#
# How long to keep polling a job before the bot gives up (ms). Default
# 1200000 = 20 min. The bot keeps a best-effort background poll going
# after this for the lifetime of the process.
# TELEGRAM_POLL_TIMEOUT_MS=1200000
